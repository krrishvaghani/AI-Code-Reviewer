# Full URL of the deployed FastAPI backend.
# Leave empty (or omit) for local development — Vite's dev proxy handles it.
# Set this in Vercel's Environment Variables panel for production builds.
#
# Example (Render):
#   VITE_API_BASE_URL=https://ai-code-reviewer-api.onrender.com
#
VITE_API_BASE_URL=
